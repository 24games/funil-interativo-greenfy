{
  "functions": {
    "api/webhook-purchase.js": {
      "maxDuration": 10
    },
    "api/tracking-pageview.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/webhook-purchase",
      "destination": "/api/webhook-purchase.js"
    },
    {
      "source": "/api/tracking-pageview",
      "destination": "/api/tracking-pageview.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}





